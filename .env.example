# ── BULK MODEL (fast, extraction/filtering) ──
BULK_PROVIDER=vllm
BULK_MODEL=Qwen/Qwen3.5-0.8B
BULK_API_URL=http://vllm:8000/v1
BULK_API_KEY=
BULK_MAX_MODEL_LEN=262144
BULK_MAX_TOKENS=16384
BULK_QUANTIZATION=fp8

# ── SYNTHESIS MODEL (smart, final reports) ──
SYNTHESIS_PROVIDER=vllm
SYNTHESIS_MODEL=cyankiwi/Qwen3.5-9B-AWQ-4bit
SYNTHESIS_API_URL=http://vllm:8000/v1
SYNTHESIS_API_KEY=
SYNTHESIS_MAX_MODEL_LEN=262144
SYNTHESIS_MAX_TOKENS=32768
SYNTHESIS_QUANTIZATION=awq

# ── GPU CONFIG ──
GPU_MEMORY_UTILIZATION=0.95
GPU_DEVICE=GPU-3ad3e2fe
KV_CACHE_DTYPE=fp8

# ── SERVICES ──
SEARXNG_URL=http://searxng:8888
HIVEMIND_URL=http://hiveminddb:8100

# ── RESEARCH DEFAULTS ──
MAX_DEPTH=3
SWARM_AGENTS=5
MAX_CONCURRENT_FETCHES=50
MAX_CONCURRENT_LLM=100
QUERIES_PER_SOURCE=4
QUALITY_THRESHOLD=4

# ── OPTIONAL API KEYS (all sources work free without these) ──
GITHUB_TOKEN=
HF_TOKEN=
